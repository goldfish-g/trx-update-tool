{
    // This file is used to enable the -l argument support.

    "engine": 2,

    "main_menu_picture": "title_eu.webp",
    "savegame_file_fmt": "save_tr2_custom_%02d.dat",

    "demo_version": false,
    "enable_tr2_item_drops": true,
    "convert_dropped_guns": true,

    "sfx_path": "main.sfx",
    "injections": [
        "font.bin",
        "lara_animations.bin",
        "lara_guns.bin",
        "pda_model.bin",
        "pickup_aid.bin",
        "winston_model.bin",
        "purple_crystal.bin",
        "lara_extra.bin",
        "lara_rifle_sfx.bin",
        "secret_models_og.bin",
        "misc_sprites.bin",
        "lara_outfits.bin",
    ],

    "levels": [
        {
            "path": "PLACEHOLDER",
            "music_track": -1,
            "lara_outfit": "tr2_classic",
            "sequence": [
                {"type": "loop_game"},
                {"type": "level_stats"},
            ],
        },
    ],
}
