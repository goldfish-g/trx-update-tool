        },
        "visuals.enable_exit_fade_effects": {
            "title": "Przejścia przy wyjściu z gry",
            "description": "Włącza efekt płynnego przejścia przy wychodzeniu z gry do pulpitu.",
        },
        "visuals.enable_fade_effects": {
            "title": "Efekty przejścia",
            "description": "Włącza efekty płynnych przejść, np. między grafikami napisów końcowych, lub przy włączaniu ekranu ekwipunku i ekranu pauzy.",
        },
        "visuals.enable_fire_lighting": {
            "title": "Światło dookoła ogni",
