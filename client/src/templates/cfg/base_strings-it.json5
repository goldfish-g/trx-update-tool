        },
        "ui.enemy_healthbar_color_allies_ps1": {
            "title": "Colore barra alleati",
            "description": "Colore utilizzato per la barra della salute degli alleati. La barra viene mostrata nella stessa posizione della barra della salute dei nemici.",
        },
        "ui.enemy_healthbar_color_ps1": {
